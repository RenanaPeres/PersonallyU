{% doc %}
  @prompt
    Two columnn - Each column is in the following way from top to bottom: Circled Shaped Image with background #F1EEE6. Both images and text are centerd in the section and equally sized. Images and text are aligned to other sections, making them be in the center. ALSO text-align : left
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-two-column-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.column_gap }}px;
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-two-column-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.image_text_gap }}px;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.image_background_color }};
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-two-column-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-two-column-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-two-column-content-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.text_max_width }}px;
    text-align: left;
  }

  .ai-two-column-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    font-weight: 600;
  }

  .ai-two-column-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-two-column-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_row_gap }}px;
    }

    .ai-two-column-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_size | times: 0.8 }}px;
      height: {{ block.settings.image_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-two-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column-container-{{ ai_gen_id }}">
    <div class="ai-two-column-item-{{ ai_gen_id }}">
      <div class="ai-two-column-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_1 %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 600 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="600"
            height="600"
          >
        {% else %}
          <div class="ai-two-column-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      <div class="ai-two-column-content-{{ ai_gen_id }}">
        {% if block.settings.heading_1 != blank %}
          <h3 class="ai-two-column-heading-{{ ai_gen_id }}">{{ block.settings.heading_1 }}</h3>
        {% endif %}
        {% if block.settings.text_1 != blank %}
          <div class="ai-two-column-text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</div>
        {% endif %}
      </div>
    </div>

    <div class="ai-two-column-item-{{ ai_gen_id }}">
      <div class="ai-two-column-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 600 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="600"
            height="600"
          >
        {% else %}
          <div class="ai-two-column-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      <div class="ai-two-column-content-{{ ai_gen_id }}">
        {% if block.settings.heading_2 != blank %}
          <h3 class="ai-two-column-heading-{{ ai_gen_id }}">{{ block.settings.heading_2 }}</h3>
        {% endif %}
        {% if block.settings.text_2 != blank %}
          <div class="ai-two-column-text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Two column with images",
  "settings": [
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading",
      "default": "Column heading"
    },
    {
      "type": "richtext",
      "id": "text_1",
      "label": "Text",
      "default": "<p>Add your text content here</p>"
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading",
      "default": "Column heading"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Text",
      "default": "<p>Add your text content here</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 900
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_row_gap",
      "label": "Mobile row gap",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Image style"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image size",
      "min": 100,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 200
    },
    {
      "type": "color",
      "id": "image_background_color",
      "label": "Background color",
      "default": "#F1EEE6"
    },
    {
      "type": "range",
      "id": "image_text_gap",
      "label": "Image to text gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_max_width",
      "label": "Text max width",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1b1818"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1b1818"
    }
  ],
  "presets": [
    {
      "name": "Two column with images"
    }
  ]
}
{% endschema %}
