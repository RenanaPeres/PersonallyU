{% doc %}
  @prompt
    4 image colllage with place for text description below each imagee. Create custom CSS code to center an image collage block horizontally on the page. The CSS should target the image collage container and apply margin auto or flexbox centering to ensure the 4-image collage is centered within its section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-collage-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-image-collage-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-image-collage-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-image-collage-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-image-collage-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-image-collage-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-collage-image-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ai-image-collage-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-image-collage-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-image-collage-container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<image-collage-{{ ai_gen_id }} class="ai-image-collage-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-collage-container-{{ ai_gen_id }}">
    <div class="ai-image-collage-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign text_key = 'text_' | append: i
          assign image = block.settings[image_key]
          assign text = block.settings[text_key]
        %}
        
        <div class="ai-image-collage-item-{{ ai_gen_id }}">
          <div class="ai-image-collage-image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
          
          {% if text != blank %}
            <div class="ai-image-collage-text-{{ ai_gen_id }}">
              {{ text }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</image-collage-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageCollage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustImageAspectRatios();
      }

      adjustImageAspectRatios() {
        const wrappers = this.querySelectorAll('.ai-image-collage-image-wrapper-{{ ai_gen_id }}');
        wrappers.forEach(wrapper => {
          wrapper.style.aspectRatio = '{{ block.settings.aspect_ratio }}';
        });
      }
    }

    customElements.define('image-collage-{{ ai_gen_id }}', ImageCollage{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image collage",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Space between images",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "16/9",
          "label": "Wide (16:9)"
        }
      ],
      "default": "1/1"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    },
    {
      "type": "header",
      "content": "Text descriptions"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Description 1"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Description 2"
    },
    {
      "type": "textarea",
      "id": "text_3",
      "label": "Description 3"
    },
    {
      "type": "textarea",
      "id": "text_4",
      "label": "Description 4"
    },
    {
      "type": "range",
      "id": "text_gap",
      "label": "Space between image and text",
      "min": 4,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1b1818"
    }
  ],
  "presets": [
    {
      "name": "Image collage"
    }
  ]
}
{% endschema %}
