  <!-- MODAL-X -->
  <div id="welcome-modal" class="modal">
    <div class="modal-content">
      <span class="close">&times;</span>
      <h2>Welcome to <span class="highlight">Personally U</span></h2>
      <p class="modal-text">
        <a href="https://huji.questionpro.eu/a/TakeSurvey?tt=P/VDme5CUhAD5ltxMh/wHg%3D%3D" target="_blank">
          <button class="modal-button">Start Personalization</button>
        </a>
      </p>
      <p class="modal-subtext">or <span class="close-text">continue with standard shopping</span></p>
    </div>
  </div>

  <style>
    /* Modal Overlay */
    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(5px);
      opacity: 0;
      animation: fadeIn 0.5s ease-in-out forwards;
    }

    /* Modal Content */
    .modal-content {
      background: #fff;
      padding: 30px;
      margin: 15% auto;
      width: 40%;
      max-width: 500px;
      text-align: center;
      border-radius: 12px;
      box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.2);
      transform: scale(0.8);
      animation: slideUp 0.5s ease-in-out forwards;
    }

    /* Title */
    .highlight {
      color: #333;
      font-weight: bold;
      font-size: 22px;
      letter-spacing: 0.5px;
    }

    /* Button */
    .modal-button {
      background: #000;
      color: #fff;
      border: 2px solid #000;
      padding: 12px 20px;
      border-radius: 8px;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.3s ease-in-out;
      box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.4);
    }

    .modal-button:hover {
      background: #fff;
      color: #000;
      transform: scale(1.01);
      box-shadow: 0px 6px 15px rgba(0, 0, 0, 0.6);
    }

    /* Close Button */
    .close {
      float: right;
      font-size: 24px;
      font-weight: bold;
      cursor: pointer;
      transform: scale(1.35);
      transition: color 0.3s ease-in-out;
      color: #666;
    }

    .close:hover {
      color: #000;
    }

    /* Close Text */
    .close-text {
      color: #888;
      font-size: 14px;
      text-decoration: underline;
      cursor: pointer;
      transition: color 0.3s ease-in-out;
    }

    .close-text:hover {
      color: #000;
    }

    /* Animations */
    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes slideUp {
      from {
        transform: scale(0.8) translateY(20px);
      }
      to {
        transform: scale(1) translateY(0);
      }
    }
  </style>

  <script>
$(function () {
  if (!localStorage.getItem("hasVisited")) {
    $("#welcome-modal").css("display", "block");
    localStorage.setItem("hasVisited", "true");
  }

  $(".close, .close-text").on("click", function () {
    $("#welcome-modal").css("display", "none");
  });
});

  </script>

