  if (!Array.isArray(designKeys)) return [null, null, null];
  const designURLs = designKeys.map(key => designedProductsImageURLs[key] || null);
  return designURLs;
}

  function updateLabels() {
    const [url1, url2, url3] = getImageURLs();
