      "default": 4
    },
    {
      "type": "range",
      "id": "circle_shadow_blur",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Shadow blur",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Two column circles"
    }
  ]
}
{% endschema %}
