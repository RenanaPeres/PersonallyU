      "max": 400,
      "step": 20,
      "unit": "px",
      "label": "Circle size",
      "default": 200
    },
    {
      "type": "range",
      "id": "circle_gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Gap between circles",
      "default": 20
    },
    {
      "type": "range",
      "id": "circle_shadow_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Shadow opacity",
      "default": 0.2
