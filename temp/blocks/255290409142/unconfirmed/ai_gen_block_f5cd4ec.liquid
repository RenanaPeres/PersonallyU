{% doc %}
  @prompt
    I want the section called "Two column circles" but with possibliy text  to the right, left or center
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-circles-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-two-column-circles__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-two-column-circles__wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.column_gap }}px;
    flex-direction: {% if block.settings.text_position == 'left' %}row-reverse{% else %}row{% endif %};
  }

  .ai-two-column-circles__text-column-{{ ai_gen_id }} {
    flex: 1;
    text-align: {% if block.settings.text_position == 'center' %}center{% else %}left{% endif %};
  }

  .ai-two-column-circles__circles-column-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    gap: {{ block.settings.circle_gap }}px;
    justify-content: {% if block.settings.text_position == 'center' %}center{% elsif block.settings.text_position == 'left' %}flex-start{% else %}flex-end{% endif %};
    flex-wrap: wrap;
  }

  .ai-two-column-circles__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-two-column-circles__text-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.text_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-two-column-circles__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-two-column-circles__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-two-column-circles__circle-{{ ai_gen_id }} {
    width: {{ block.settings.circle_size }}px;
    height: {{ block.settings.circle_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 {{ block.settings.circle_shadow_vertical }}px {{ block.settings.circle_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.circle_shadow_opacity }});
  }

  .ai-two-column-circles__circle-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-two-column-circles__circle-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-two-column-circles__circle-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-two-column-circles__wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-two-column-circles__text-column-{{ ai_gen_id }} {
      text-align: center;
    }

    .ai-two-column-circles__circles-column-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-two-column-circles__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-two-column-circles__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-two-column-circles__circle-{{ ai_gen_id }} {
      width: calc({{ block.settings.circle_size }}px * 0.8);
      height: calc({{ block.settings.circle_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-two-column-circles-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column-circles__container-{{ ai_gen_id }}">
    <div class="ai-two-column-circles__wrapper-{{ ai_gen_id }}">
      <div class="ai-two-column-circles__text-column-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-two-column-circles__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-two-column-circles__text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-two-column-circles__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>

      <div class="ai-two-column-circles__circles-column-{{ ai_gen_id }}">
        {% for i in (1..2) %}
          {% liquid
            assign image_key = 'circle_image_' | append: i
            assign circle_image = block.settings[image_key]
          %}
          <div class="ai-two-column-circles__circle-{{ ai_gen_id }}">
            {% if circle_image %}
              <img
                src="{{ circle_image | image_url: width: 600 }}"
                alt="{{ circle_image.alt | escape }}"
                class="ai-two-column-circles__circle-image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              <div class="ai-two-column-circles__circle-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Two column circles",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Column gap",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Mobile gap",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f1eee6"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Discover our story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Share your brand story and connect with your customers. Explain what makes your products unique and why people love them.</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Heading spacing",
      "default": 20
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1b1818"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_spacing",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Text spacing",
      "default": 25
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1b1818"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#1b1818"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#3f5147"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
